# Copy this file to .env and fill in your own values there.
# Fill in .env yourself in an editor -- do not paste these into chat.

# From your Autodesk Platform Services app (already added as a Custom Integration
# in ACC Account Admin > Settings > Custom Integrations).
APS_CLIENT_ID=
APS_CLIENT_SECRET=

# Your ACC account/hub id. Leave blank and run `python main.py --list-hubs` once
# to discover it, then paste it here.
ACC_ACCOUNT_ID=

# Optional. Only needed if the Account Admin "list all projects" call comes back
# limited to projects the app itself is a member of -- try without it first.
# Must be an email of a Hub Admin / Account Admin on the ACC account.
ACC_IMPERSONATE_USER_EMAIL=
